# Supabase Configuration
VITE_MULTIPLY_AI_SUPABASE_URL=
VITE_MULTIPLY_AI_SUPABASE_ANON_KEY=
MULTIPLY_AI_SUPABASE_URL=
MULTIPLY_AI_SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini Configuration
# MULTIPLY_AI_GOOGLE_API_KEY is preferred for app-specific deployment.
# GOOGLE_AI_API_KEY and GEMINI_API_KEY are accepted fallbacks for local shells.
MULTIPLY_AI_GOOGLE_API_KEY=
MULTIPLY_AI_GEMINI_MODEL=gemini-2.5-flash

# Census API Configuration
# Optional. The server falls back to DEMO_KEY when this is empty.
MULTIPLY_AI_CENSUS_API_KEY=

# Server Configuration
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
